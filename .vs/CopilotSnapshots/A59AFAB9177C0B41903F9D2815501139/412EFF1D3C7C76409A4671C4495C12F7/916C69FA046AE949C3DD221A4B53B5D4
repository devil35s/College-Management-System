        private void LoadStudentReport()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(cs))
                {
                    string query = @"SELECT 
                                StudentId AS [Student ID],
                                FirstName AS [First Name],
                                LastName AS [Last Name],
                                Gender AS [Gender],
                                Phone AS [Contact],
                                Email AS [Email],
                                Address AS [Address],
                                EnrollmentNo AS [Enrollment No],
                                Course AS [Course],
                                Semester AS [Semester],
                                CONVERT(varchar, DateOfBirth, 105) AS [Date Of Birth],
                                Status AS [Status]
                             FROM dbo.Student
                             WHERE 1=1";

                    SqlCommand cmd = new SqlCommand();
                    cmd.Connection = con;

                    // Search by ID / First Name / Last Name
                    if (!string.IsNullOrWhiteSpace(txtSearch.Text))
                    {
                        query += @" AND (
                                CAST(StudentId AS varchar) LIKE @search
                                OR FirstName LIKE @search
                                OR LastName LIKE @search
                            )";
                        cmd.Parameters.AddWithValue("@search", "%" + txtSearch.Text.Trim() + "%");
                    }

                    // Status filter
                    if (cmbStatus.SelectedItem != null && cmbStatus.Text != "All")
                    {
                        query += " AND Status = @status";
                        cmd.Parameters.AddWithValue("@status", cmbStatus.Text);
                    }

                    // Course filter
                    if (cmbClassDepartment.SelectedItem != null && cmbClassDepartment.Text != "All Courses")
                    {
                        query += " AND Course = @course";
                        cmd.Parameters.AddWithValue("@course", cmbClassDepartment.Text);
                    }

                    // Semester filter
                    if (cmbSemester.SelectedItem != null && cmbSemester.Text != "All Semesters")
                    {
                        query += " AND Semester = @semester";
                        cmd.Parameters.AddWithValue("@semester", cmbSemester.Text);
                    }
                    // DOB filter
                    if (dtpFrom.Checked)
                    {
                        query += " AND CAST(DateOfBirth AS DATE) = @dob";
                        cmd.Parameters.AddWithValue("@dob", dtpFrom.Value.Date);
                    }

                    // Email filter
                    if (!string.IsNullOrWhiteSpace(txtEmail.Text))
                    {
                        query += " AND Email LIKE @email";
                        cmd.Parameters.AddWithValue("@email", "%" + txtEmail.Text.Trim() + "%");
                    }
                    cmd.CommandText = query;

                    DataTable dt = new DataTable();
                    SqlDataAdapter da = new SqlDataAdapter(cmd);   // IMPORTANT
                    da.Fill(dt);

                    dgvReport.DataSource = null;
                    dgvReport.Columns.Clear();
                    dgvReport.AutoGenerateColumns = true;
                    dgvReport.DataSource = dt;

                    if (dgvReport.Rows.Count > 0)
                    {
                        dgvReport.FirstDisplayedScrollingColumnIndex = 0;
                    }

                    dgvReport.AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.None;
                    dgvReport.ScrollBars = ScrollBars.Both;

                    dgvReport.Columns["Student ID"].Width = 100;
                    dgvReport.Columns["First Name"].Width = 130;
                    dgvReport.Columns["Last Name"].Width = 130;
                    dgvReport.Columns["Gender"].Width = 90;
                    dgvReport.Columns["Contact"].Width = 130;
                    dgvReport.Columns["Email"].Width = 220;
                    dgvReport.Columns["Address"].Width = 220;
                    dgvReport.Columns["Enrollment No"].Width = 140;
                    dgvReport.Columns["Course"].Width = 120;
                    dgvReport.Columns["Semester"].Width = 100;
                    dgvReport.Columns["Date Of Birth"].Width = 120;
                    dgvReport.Columns["Status"].Width = 100;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show("Error while loading student report: " + ex.Message);
            }
        }

        private void LoadTotalStudentsCount()
        {
            try
            {
                using (SqlConnection con = new SqlConnection(cs))
                {
                    string query = "SELECT COUNT(*) FROM dbo.Student";
                    SqlCommand cmd = new SqlCommand(query, con);

                    con.Open();
                    int totalStudents = Convert.ToInt32(cmd.ExecuteScalar());

                    lblTotalStudentsValue.Text = totalStudents.ToString();
                }
